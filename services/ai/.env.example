AI_ENVIRONMENT=local
AI_LOG_LEVEL=INFO

# Path to a Stockfish/UCI binary. Leave unset to run baseline bots only.
# macOS (brew): /opt/homebrew/bin/stockfish   Debian/Docker: /usr/games/stockfish
# AI_STOCKFISH_PATH=/opt/homebrew/bin/stockfish

# Default per-move limits (overridable per request via constraints).
AI_DEFAULT_MOVETIME_MS=100
AI_DEFAULT_SEARCH_DEPTH=3
