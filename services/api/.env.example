# Copy to .env for local runs. Compose injects these for containers.
CHESS_ENVIRONMENT=local
CHESS_LOG_LEVEL=INFO

# Async SQLAlchemy URL. Local Compose Postgres:
CHESS_DATABASE_URL=postgresql+asyncpg://chess:chess@localhost:5432/chess

# Optional in Phase 1 (no Redis needed for correctness). Leave unset to skip the
# readiness check; set it once Phase 4 (multiplayer) introduces coordination.
# CHESS_REDIS_URL=redis://localhost:6379/0

# Development identity seam (Phase 1 has no real auth yet). Any request without
# an X-Dev-User header is attributed to this user id.
CHESS_DEV_USER_ID=00000000-0000-0000-0000-000000000001

# AI service (services/ai). Unset = ai-mode games fall back to a local random move.
# CHESS_AI_BASE_URL=http://localhost:8001
CHESS_AI_REQUEST_TIMEOUT_MS=2000
CHESS_AI_RETRIES=2
CHESS_AI_FALLBACK_TO_RANDOM=true
CHESS_AI_DEFAULT_DIFFICULTY=heuristic
